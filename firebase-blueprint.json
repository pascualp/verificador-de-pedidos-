{
  "entities": {
    "Chat": {
      "title": "Processed WhatsApp Chat",
      "description": "A record of a processed WhatsApp chat.",
      "type": "object",
      "properties": {
        "clientName": { "type": "string" },
        "processingMethod": { "type": "string" },
        "processedContent": { "type": "string" },
        "date": { "type": "string" },
        "keywords": { "type": "array", "items": { "type": "string" } },
        "userId": { "type": "string" },
        "createdAt": { "type": "timestamp" }
      },
      "required": ["clientName", "processingMethod", "processedContent", "date", "userId", "createdAt"]
    }
  },
  "firestore": {
    "chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "Stores processed WhatsApp chats."
    }
  }
}
